datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}
model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  password           String
  name               String?
  role               String   @default("user")

  tier               String   @default("free")
  subscriptionStatus String   @default("inactive")
  subscriptionType   String   @default("none")
  subscriptionId     String?
  provider           String?
  lemonCustomerId    String?
  stripeCustomerId   String?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  drafts    Draft[]
  sessions  Session[]

  @@index([createdAt])
  @@index([tier])
}

model Session {
  token     String   @id
  email     String
  createdAt DateTime @default(now())
  expiresAt DateTime
  user      User     @relation(fields: [email], references: [email])
}

model Draft {
  id              String   @id @default(uuid())
  userId          String
  title           String
  content         String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tierAtCreation  String
  user            User     @relation(fields: [userId], references: [id])
  versions        DraftVersion[]
}

model Invite {
  id         String   @id @default(uuid())
  email      String
  inviterId  String
  tier       String
  status     String   // "pending" | "accepted" | "cancelled"
  sentAt     DateTime
  acceptedAt DateTime?
}

model DraftVersion {
  id        String   @id @default(cuid())
  draftId   String
  content   String
  createdAt DateTime @default(now())

  draft     Draft    @relation(fields: [draftId], references: [id])
}

model AiLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String   // "generate" | "improve" | "template" | "score"
  createdAt DateTime @default(now())

  @@index([action])
  @@index([createdAt])
  @@index([userId])
}

model ErrorLog {
  id        String   @id @default(cuid())
  message   String
  endpoint String?
  userId   String?
  severity String   @default("info") // "critical" | "warning" | "info"
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([severity])
}

model LifetimeTier {
  id        String   @id @default(cuid())
  userId    String?
  claimed   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([claimed])
}