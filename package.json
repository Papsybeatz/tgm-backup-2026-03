{
  "name": "the-grants-master",
  "version": "1.0.0",
  "description": "Modular agentic workflow engine for grant writing and SaaS deployment.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "vite",
    "test:landing": "node test-landing.js",
    "build": "vite build",
    "build:agents": "esbuild src/index.js --bundle --platform=node --outfile=dist/index.js",
    "build:frontend": "cd app/frontend && npm run build",
    "build:backend": "cd app/backend && npm run build",
    "deploy:vercel": "vercel --prod",
    "deploy:railway": "railway up",
    "deploy:bundle": "tar -czvf grants-master-bundle.tar.gz dist app",
    "backend": "node server.js",
    "start": "node server.js",
    "test": "jest tests/api",
    "test:e2e": "playwright test tests/e2e"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.0.0",
    "@prisma/client": "^7.2.0",
    "@sendgrid/mail": "^8.1.6",
    "cors": "^2.8.5",
    "dayjs": "^1.11.19",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "groq": "^5.20.0",
    "i18next": "^25.8.0",
    "openai": "^6.33.0",
    "react": ">=18.0.0",
    "react-dom": "^19.2.3",
    "react-i18next": "^16.5.3",
    "react-router-dom": "^7.11.0",
    "@tanstack/react-query": "^5.0.0",
    "framer-motion": "^10.12.16",
    "uuid": "^13.0.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "keywords": [
    "agents",
    "workflow-engine",
    "grant-writing",
    "ai-saas"
  ],
  "license": "MIT",
  "devDependencies": {
    "http-proxy-middleware": "^2.0.6",
    "http-proxy-middleware": "^2.0.6",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.4.23",
    "postcss": "^8.5.6",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.1.18",
    "vite": "^7.3.1"
  }
}
