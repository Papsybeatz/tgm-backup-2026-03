{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://tgm-backup-2026-03-production-ea59.up.railway.app/api/:path*"
    }
  ],
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(.*\\.(js|css|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot|map))",
      "dest": "/$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "https://tgm-backup-2026-03-production-ea59.up.railway.app/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
